# DATABASE_URL: PostgreSQL connection string (Railway fornece automaticamente)
DATABASE_URL="postgresql://user:password@localhost:5432/admin_db"

# JWT_SECRET: Chave secreta para assinar tokens JWT (use uma string longa e aleatória)
JWT_SECRET="your_very_secret_key_here"

# PORT: Porta do servidor (Railway injeta automaticamente)
PORT=3000

# NODE_ENV
NODE_ENV="production"

# GEMINI_API_KEY (opcional, se usar IA)
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
